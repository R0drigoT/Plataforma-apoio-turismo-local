@using ProjetoFim.Resources
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - @Strings.Footer_Copy</title>
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
    @RenderSection("styles", required: false)
</head>
@{
    var currentLang = (string)ViewContext.RouteData.Values["lang"] ?? "pt";

    var routeVals = new System.Web.Routing.RouteValueDictionary(ViewContext.RouteData.Values);
    var ctrl = (string)routeVals["controller"] ?? "Home";
    var act = (string)routeVals["action"] ?? "Index";
    var id = routeVals.ContainsKey("id") ? routeVals["id"] : null;

    Func<string, string> langUrl = l => Url.Action(act, ctrl, new { lang = l, id = id }) + Request.Url.Query;
}

<body>
    <header>
        <nav class="navbar">
            <div class="navbar-container">
                <a href="@Url.Action(User.Identity.IsAuthenticated ? (User.IsInRole("Admin") ? "Dashboard" : "Homepage") : "Index", "Home", new { lang = currentLang })" class="navbar-logo">
                    <img src="~/Content/images/loccall_logo_transparent.png" alt="Logo">
                </a>
                <div class="navbar-menu">
                    @if (User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            <a href="@Url.Action("GerirAnuncios", "Home", new { lang = currentLang })">@Strings.Navbar_Ads</a>
                            <a href="@Url.Action("ListaReservas", "Home", new { lang = currentLang })">@Strings.Navbar_Bookings</a>
                            <a href="@Url.Action("Calendario", "Home", new { lang = currentLang })">@Strings.Navbar_Calendar</a>
                            <a href="@Url.Action("CaixaDeEntrada", "Mensagem", new { lang = currentLang })">@Strings.Navbar_Inbox</a>
                            <a href="@Url.Action("Estatisticas", "Home", new { lang = currentLang })">@Strings.Navbar_Stats</a>
                        }
                        else
                        {
                            <a href="@Url.Action("Reservas", "Home", new { lang = currentLang })">@Strings.Navbar_Bookings</a>
                            <a href="@Url.Action("Favoritos", "Home", new { lang = currentLang })">@Strings.Navbar_Favorites</a>
                        }
                        <div class="language-selector-container">
                            <a href="#" id="languageMenuLink" class="navbar-link">
                                <i class="fas fa-globe"></i> @Strings.Navbar_Language
                            </a>
                            <div class="language-dropdown">
                                <a class="dropdown-link" href="@langUrl("pt")">@Strings.Language_PT</a>
                                <a class="dropdown-link" href="@langUrl("en")">@Strings.Language_EN</a>
                                <a class="dropdown-link" href="@langUrl("es")">@Strings.Language_ES</a>
                                <a class="dropdown-link" href="@langUrl("fr")">@Strings.Language_FR</a>
                            </div>
                        </div>
                        <div class="user-menu-container">
                            <div class="user-icon-wrapper" id="userMenuIcon">
                                <i class="fas fa-bars"></i>
                                <i class="fas fa-user-circle"></i>
                            </div>
                            <div id="loginOptions" class="login-options clean-menu">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="login-section">
                                        <a href="@Url.Action("Notificacoes", "Home", new { lang = currentLang })" class="dropdown-link">@Strings.Menu_Notifications</a>
                                        <a href="@Url.Action("ListaAvaliacoes", "Home", new { lang = currentLang })" class="dropdown-link">@Strings.Menu_Reviews</a>
                                        <a href="@Url.Action("HistoricoTransacoes", "Home", new { lang = currentLang })" class="dropdown-link">@Strings.Menu_TransactionsHistory</a>
                                    </div>
                                    <div class="login-section">
                                        @using (Html.BeginForm("Logout", "Account", FormMethod.Post, new { id = "logoutFormAdmin" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <a href="javascript:document.getElementById('logoutFormAdmin').submit()" class="dropdown-link">@Strings.Menu_Logout</a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="login-section">
                                        <a href="@Url.Action("Index", "Mensagem", new { lang = currentLang })" class="dropdown-link">@Strings.Menu_Messages</a>
                                        <a href="@Url.Action("Notificacoes", "Home", new { lang = currentLang })" class="dropdown-link">@Strings.Menu_Notifications</a>
                                        <a href="@Url.Action("HistoricoTransacoes", "Home", new { lang = currentLang })" class="dropdown-link">@Strings.Menu_TransactionsHistory</a>
                                    </div>
                                    <div class="login-section">
                                        <a href="@Url.Action("Perfil", "Home", new { lang = currentLang })" class="dropdown-link">@Strings.Menu_Profile</a>
                                        @using (Html.BeginForm("Logout", "Account", FormMethod.Post, new { id = "logoutForm" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <a href="javascript:document.getElementById('logoutForm').submit()" class="dropdown-link">@Strings.Menu_Logout</a>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="language-selector-container">
                            <a href="#" id="languageMenuLink" class="navbar-link">
                                <i class="fas fa-globe"></i> @Strings.Navbar_Language
                            </a>
                            <div class="language-dropdown">
                                <a class="dropdown-link" href="@langUrl("pt")">@Strings.Language_PT</a>
                                <a class="dropdown-link" href="@langUrl("en")">@Strings.Language_EN</a>
                                <a class="dropdown-link" href="@langUrl("es")">@Strings.Language_ES</a>
                                <a class="dropdown-link" href="@langUrl("fr")">@Strings.Language_FR</a>
                            </div>
                        </div>
                        <div class="user-menu-container">
                            <div class="user-icon-wrapper" id="userMenuIcon">
                                <i class="fas fa-bars"></i>
                                <i class="fas fa-user-circle"></i>
                            </div>
                            <div id="loginOptions" class="login-options">
                                <div class="login-section">
                                    <strong>@Strings.Menu_User</strong>
                                    <a href="#" id="openRegisterBtn" class="btn-login">@Strings.Auth_Register_Btn</a>
                                    <a href="#" id="openLoginBtn" class="btn-login">@Strings.Auth_Login_Btn</a>
                                </div>
                                <div class="login-section">
                                    <strong>@Strings.Menu_Admin</strong>
                                    <a href="#" id="openAdminLoginBtn" class="btn-login">@Strings.Auth_AdminLogin</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container body-content">
        @RenderBody()
    </div>
    @if (!User.Identity.IsAuthenticated)
    {
        <div id="loginModal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>@Strings.Auth_Login_Btn</h2>
                    <button class="close-btn">&times;</button>
                </div>
                <form action="@Url.Action("Login", "Account")" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="login-username">@Strings.Auth_Username</label>
                            <input type="text" id="login-username" name="Username" placeholder="@Strings.Auth_Username" required>
                        </div>
                        <div class="form-group">
                            <label for="login-password">@Strings.Auth_Password</label>
                            <input type="password" id="login-password" name="Password" placeholder="@Strings.Auth_Password" required>
                        </div>
                        <a href="#" class="forgot-password">@Strings.Auth_ForgotPassword</a>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="modal-btn">@Strings.Auth_Continue</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="registerModal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>@Strings.Auth_Register_Btn</h2>
                    <button class="close-btn">&times;</button>
                </div>
                <form id="registerForm" action="@Url.Action("Registar", "Account", new { lang = currentLang })" method="post">
                    <div class="modal-body">
                        <div id="register-errors" class="form-errors"></div>
                        <div class="form-group">
                            <label for="reg-username">@Strings.Auth_Username</label>
                            <input type="text" id="reg-username" name="Username" placeholder="@Strings.Auth_Username" required>
                        </div>
                        <div class="form-group">
                            <label for="reg-email">@Strings.Auth_Email</label>
                            <input type="email" id="reg-email" name="Email" placeholder="@Strings.Auth_Email" required>
                        </div>
                        <div class="form-group">
                            <label for="reg-dob">@Strings.Auth_DateOfBirth</label>
                            <input type="text" id="reg-dob" name="DateOfBirth" required placeholder="dd/mm/aaaa">
                        </div>
                        <div class="form-group">
                            <label for="reg-password">@Strings.Auth_Password</label>
                            <input type="password" id="reg-password" name="Password" placeholder="@Strings.Auth_Password" required>
                        </div>
                        <div class="form-group">
                            <label for="reg-confirm-password">@Strings.Auth_ConfirmPassword</label>
                            <input type="password" id="reg-confirm-password" name="ConfirmPassword" placeholder="@Strings.Auth_ConfirmPassword" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="registerSubmitBtn" class="modal-btn">@Strings.Auth_Continue</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="adminLoginModal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>@Strings.Auth_AdminLogin</h2>
                    <button class="close-btn">&times;</button>
                </div>
                <form action="@Url.Action("AdminLogin", "Account")" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="admin-username">@Strings.Auth_Username</label>
                            <input type="text" id="admin-username" name="Username" placeholder="@Strings.Auth_Username" required>
                        </div>
                        <div class="form-group">
                            <label for="admin-password">@Strings.Auth_Password</label>
                            <input type="password" id="admin-password" name="Password" placeholder="@Strings.Auth_Password" required>
                        </div>
                        <a href="#" class="forgot-password">@Strings.Auth_ForgotPassword</a>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="modal-btn">@Strings.Auth_Continue</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div id="forgotPasswordModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2>@Strings.Auth_ForgotPassword</h2>
                <button id="closeForgotPasswordModal" class="close-btn">&times;</button>
            </div>

            <form id="forgotPasswordForm">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="forgot-email">@Strings.Auth_Email</label>
                        <input type="email"
                               id="forgot-email"
                               name="Email"
                               placeholder="@Strings.Auth_Email"
                               required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="forgotSubmitBtn" class="modal-btn">@Strings.Auth_Continue</button>
                </div>
            </form>
        </div>
    </div>

    <div id="contactModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2>@Strings.Contact_Title</h2>
                <button id="closeContactModal" class="close-btn">&times;</button>
            </div>
            <form id="contactForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="contactQuartoId" name="quartoId" />
                <input type="hidden" id="contactServicoId" name="servicoId" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="contactMessage">@Strings.Contact_MessageLabel</label>
                        <textarea id="contactMessage" name="conteudo" rows="5" required placeholder="@Strings.Contact_MessagePlaceholder"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="modal-btn">@Strings.Contact_Send</button>
                </div>
            </form>
        </div>
    </div>
    <div id="errorModal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h2>@Strings.Error_Title</h2>
                <button id="closeErrorModal" class="close-btn">&times;</button>
            </div>
            <div class="modal-body">
                <p id="errorMessageText"></p>
            </div>
            <div class="modal-footer">
                <button id="confirmErrorModal" class="modal-btn">@Strings.Error_OK</button>
            </div>
        </div>
    </div>
    <div id="confirmationModal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h2>@Strings.Confirm_Title</h2>
                <button id="closeConfirmationModal" class="close-btn">&times;</button>
            </div>
            <div class="modal-body">
                <p id="confirmationMessageText"></p>
            </div>
            <div class="modal-footer" style="display: flex; gap: 10px;">
                <button id="cancelConfirmationModal" class="btn-cancel-form">@Strings.Confirm_Cancel</button>
                <button id="confirmConfirmationModal" class="modal-btn">@Strings.Confirm_OK</button>
            </div>
        </div>
    </div>
    <footer>
        <p>&copy; @DateTime.Now.Year - @Strings.Footer_Copy</p>
    </footer>
</body>
</html>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
@RenderSection("scripts", required: false)
<script>
  var I18N = {
    ForgotInfoNoEmail: "@Html.Raw(HttpUtility.JavaScriptStringEncode(Strings.Forgot_Info_NoEmail))"
  };
</script>

<script>
        const errorModal = document.getElementById('errorModal');
        if (errorModal) {
            const errorMessageText = document.getElementById('errorMessageText');
            const closeErrorModalBtn = document.getElementById('closeErrorModal');
            const confirmErrorModalBtn = document.getElementById('confirmErrorModal');

            function showErrorModal(message) {
                errorMessageText.textContent = message;
                errorModal.style.display = 'flex';
            }

            function hideErrorModal() {
                errorModal.style.display = 'none';
            }

            closeErrorModalBtn.addEventListener('click', hideErrorModal);
            confirmErrorModalBtn.addEventListener('click', hideErrorModal);
        }
        @if (TempData["LoginError"] != null)
        {
            <text>
    showErrorModal("@Html.Raw(HttpUtility.JavaScriptStringEncode(TempData["LoginError"].ToString()))");
            </text>
        }
        @if (TempData["Erro"] != null)
{
    <text>
        showErrorModal("@Html.Raw(HttpUtility.JavaScriptStringEncode(TempData["Erro"].ToString()))");
    </text>
}
@if (TempData["Sucesso"] != null)
{
    <text>
        showErrorModal("@Html.Raw(HttpUtility.JavaScriptStringEncode(TempData["Sucesso"].ToString()))");
    </text>
}

        const confirmationModal = document.getElementById('confirmationModal');
        if (confirmationModal) {
            const confirmationMessageText = document.getElementById('confirmationMessageText');
            const closeConfirmationBtn = document.getElementById('closeConfirmationModal');
            const cancelConfirmationBtn = document.getElementById('cancelConfirmationModal');
            const confirmConfirmationBtn = document.getElementById('confirmConfirmationModal');
            let confirmCallback = null;

            window.showConfirmationModal = function (message, callback) {
                confirmationMessageText.textContent = message;
                confirmCallback = callback;
                confirmationModal.style.display = 'flex';
            }

            function hideConfirmationModal() {
                confirmationModal.style.display = 'none';
            }

            confirmConfirmationBtn.addEventListener('click', function () {
                if (typeof confirmCallback === 'function') {
                    confirmCallback();
                }
                hideConfirmationModal();
            });

            closeConfirmationBtn.addEventListener('click', hideConfirmationModal);
            cancelConfirmationBtn.addEventListener('click', hideConfirmationModal);
        }
    document.addEventListener('DOMContentLoaded', function () {
        const forgotPasswordModal = document.getElementById('forgotPasswordModal');

        function openModal(modal) { if (modal) modal.style.display = 'flex'; }
        function closeModal() {
            if (typeof loginModal !== 'undefined' && loginModal) loginModal.style.display = 'none';
            if (typeof registerModal !== 'undefined' && registerModal) registerModal.style.display = 'none';
            if (typeof adminLoginModal !== 'undefined' && adminLoginModal) adminLoginModal.style.display = 'none';
            if (forgotPasswordModal) forgotPasswordModal.style.display = 'none';
        }

        document.querySelectorAll('.forgot-password').forEach(a => {
            a.addEventListener('click', function (e) {
                e.preventDefault();
                closeModal();
                openModal(forgotPasswordModal);
            });
        });
        const closeForgotBtn = document.getElementById('closeForgotPasswordModal');
        if (closeForgotBtn) closeForgotBtn.addEventListener('click', closeModal);

        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', function (event) {
                if (event.target === overlay) {
                    closeModal();
                    if (typeof contactModal !== 'undefined' && contactModal) contactModal.style.display = 'none';
                }
            });
        });
        const forgotSubmitBtn = document.getElementById('forgotSubmitBtn');
        if (forgotSubmitBtn) {
            forgotSubmitBtn.addEventListener('click', function () {
                const msg = (I18N && I18N.ForgotInfoNoEmail) ? I18N.ForgotInfoNoEmail : '';
                if (typeof window.showConfirmationModal === 'function') {
                    window.showConfirmationModal(msg, function () { });
                }
                closeModal();
                const f = document.getElementById('forgotPasswordForm');
                if (f) f.reset();
            });
        }

  var dobInput = document.getElementById('reg-dob');
  if (dobInput && typeof flatpickr !== 'undefined') {
    var lang = '@currentLang';
    var localeMap = {
      'pt': flatpickr.l10ns.pt,
      'es': flatpickr.l10ns.es,
      'fr': flatpickr.l10ns.fr,
      'en': flatpickr.l10ns.default
    };

    var today = new Date();
    var max18 = new Date(today.getFullYear() - 18, today.getMonth(), today.getDate());

    flatpickr(dobInput, {
      dateFormat: "Y-m-d",
      altInput: true,
      altFormat: "d/m/Y",
      maxDate: max18,

      locale: localeMap[lang] || flatpickr.l10ns.default
    });
  }
            const userMenuIcon = document.getElementById('userMenuIcon');
            const loginOptions = document.getElementById('loginOptions');
            const languageMenuLink = document.getElementById('languageMenuLink');
            const languageDropdown = document.querySelector('.language-dropdown');
            if (userMenuIcon) {
                userMenuIcon.addEventListener('click', function (event) {
                    event.stopPropagation();
                    if (loginOptions) {
                        loginOptions.classList.toggle('show');
                        if (languageDropdown) languageDropdown.classList.remove('show');
                    }
                });
            }
            if (languageMenuLink) {
                languageMenuLink.addEventListener('click', function (event) {
                    event.preventDefault();
                    event.stopPropagation();
                    if (languageDropdown) {
                        languageDropdown.classList.toggle('show');
                        if (loginOptions) loginOptions.classList.remove('show');
                    }
                });
            }
            document.addEventListener('click', function (event) {
                if (loginOptions && loginOptions.classList.contains('show')) {
                    const isClickInsideUserMenu = userMenuIcon.contains(event.target) || loginOptions.contains(event.target);
                    if (!isClickInsideUserMenu) {
                        loginOptions.classList.remove('show');
                    }
                }
                if (languageDropdown && languageDropdown.classList.contains('show')) {
                    const isClickInsideLangMenu = languageMenuLink.contains(event.target) || languageDropdown.contains(event.target);
                    if (!isClickInsideLangMenu) {
                        languageDropdown.classList.remove('show');
                    }
                }
            });
            if (!@User.Identity.IsAuthenticated.ToString().ToLower()) {
                const loginModal = document.getElementById('loginModal');
                const registerModal = document.getElementById('registerModal');
                const adminLoginModal = document.getElementById('adminLoginModal');
                const openLoginBtn = document.getElementById('openLoginBtn');
                const openRegisterBtn = document.getElementById('openRegisterBtn');
                const openAdminLoginBtn = document.getElementById('openAdminLoginBtn');
                const closeButtons = document.querySelectorAll('.close-btn');
                const overlays = document.querySelectorAll('.modal-overlay');

                function openModal(modal) { if (modal) modal.style.display = 'flex'; }
                function closeModal() {
                    if (loginModal) loginModal.style.display = 'none';
                    if (registerModal) registerModal.style.display = 'none';
                    if (adminLoginModal) adminLoginModal.style.display = 'none';
                }

                if (openLoginBtn) openLoginBtn.addEventListener('click', function (e) { e.preventDefault(); openModal(loginModal); });
                if (openRegisterBtn) openRegisterBtn.addEventListener('click', function (e) { e.preventDefault(); openModal(registerModal); });
                if (openAdminLoginBtn) openAdminLoginBtn.addEventListener('click', function (e) { e.preventDefault(); openModal(adminLoginModal); });

                if (closeButtons.length > 0) {
                    closeButtons.forEach(button => {
                        if (!button.id.startsWith('closeContact')) {
                            button.addEventListener('click', closeModal);
                        }
                    });
                }
                if (overlays.length > 0) {
                    overlays.forEach(overlay => {
                        overlay.addEventListener('click', function (event) {
                            if (event.target === overlay) {
                                closeModal();
                                if (contactModal) contactModal.style.display = 'none';
                            }
                        });
                    });
                }
            }
      const registerSubmitBtn = document.getElementById('registerSubmitBtn');
  if (!registerSubmitBtn) return;

  registerSubmitBtn.addEventListener('click', function (e) {
    e.preventDefault();
    const form = document.getElementById('registerForm');
    const errorDiv = document.getElementById('register-errors');
    errorDiv.style.display = 'none';
    errorDiv.innerHTML = '';

    fetch(form.action, {
      method: form.method,
      body: new FormData(form)       
    })
    .then(async (resp) => {
      if (!resp.ok) {
        const txt = await resp.text();
        throw new Error(txt || ('HTTP ' + resp.status));
      }
      return resp.json();
    })
    .then(data => {
      if (data.success) {
        window.location.href = data.redirectUrl;
      } else {
        let html = '<ul>';
        (data.errors || ['@Strings.Aviso_erro_inesperado_tente_novamente']).forEach(m => html += `<li>${m}</li>`);
        html += '</ul>';
        errorDiv.innerHTML = html;
        errorDiv.style.display = 'block';
      }
    })
    .catch(err => {
      errorDiv.innerHTML = `<ul><li>${(err && err.message) || '@Strings.Aviso_erro_inesperado_tente_novamente'}</li></ul>`;
      errorDiv.style.display = 'block';
    });
  });

            const contactModal = document.getElementById('contactModal');
            const closeContactBtn = document.getElementById('closeContactModal');
            const contactForm = document.getElementById('contactForm');
            const contactQuartoIdInput = document.getElementById('contactQuartoId');
            const contactServicoIdInput = document.getElementById('contactServicoId');

            document.body.addEventListener('click', function (event) {
                let target = event.target.closest('#openContactHostBtn');
                if (target) {
                    contactQuartoIdInput.value = '';
                    contactServicoIdInput.value = '';
                    const quartoElement = document.querySelector('[data-quarto-id]');
                    const servicoElement = document.querySelector('[data-servico-id]');
                    if (quartoElement) {
                        contactQuartoIdInput.value = quartoElement.dataset.quartoId;
                    } else if (servicoElement) {
                        contactServicoIdInput.value = servicoElement.dataset.servicoId;
                    }
                    if (contactModal) contactModal.style.display = 'flex';
                }
            });
            if (closeContactBtn) {
                closeContactBtn.addEventListener('click', () => {
                    if (contactModal) contactModal.style.display = 'none';
                });
            }
            if (contactForm) {
                contactForm.addEventListener('submit', function (e) {
                    e.preventDefault();
                    const url = '@Url.Action("IniciarConversa", "Mensagem")';
                   const formData = new FormData(this);
                    fetch(url, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            contactModal.style.display = 'none';
                            contactForm.reset();
                        } else {
                            alert('@Strings.GerirAvaliacoes_erro ' + data.message);
                        }
                    })
                    .catch(error => {
                        alert('@Strings.Aviso_erro_comunicacao');
                        console.error('Error:', error);
                    });
                });
            }
        });
        document.querySelectorAll('.scroll-btn').forEach(button => {
            button.addEventListener('click', function () {
                const targetId = this.dataset.target;
                const grid = document.getElementById(targetId);
                const scrollAmount = this.classList.contains('prev') ? -300 : 300;
                grid.scrollBy({ left: scrollAmount, behavior: 'smooth' });
            });
        });
</script>


