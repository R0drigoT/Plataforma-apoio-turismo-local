@model ProjetoFim.Models.ApplicationUser
@using System.Globalization
@using ProjetoFim.Resources

@{
    ViewBag.Title = Strings.MetodosPagamento_titulo;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="profile-page-container">
    @Html.Partial("_ProfileSummaryCard", Model)
    <main class="profile-main-content">
        <h1 class="page-title">@Strings.MetodosPagamento_titulo</h1>
        <p class="page-description">@Strings.MetodosPagamento_descricao</p>

        <div id="payment-methods-list">
            <hr class="section-divider">
            <div class="payment-method-item">
                <div class="payment-method-details">
                    <h4>@Strings.MetodosPagamento_cartoes_pagamento</h4>
                    <p>@Strings.MetodosPagamento_pague_com_novo_cartao</p>
                </div>
                <div class="payment-method-action">
                    <a href="#" id="show-add-card-form-btn">@Strings.MetodosPagamento_adicionar_cartao</a>
                </div>
            </div>
            <hr class="section-divider">
        </div>

        <div id="add-card-form" class="add-card-container">
            <div class="add-card-header">
                <h4>@Strings.MetodosPagamento_cartoes_pagamento</h4>
                <a href="#" id="cancel-add-card-btn" class="form-btn-cancel">@Strings.Confirm_Cancel</a>
            </div>
            <form class="profile-edit-form">
                <div class="form-group">
                    <label for="card-holder-name">@Strings.MetodosPagamento_nome_titular_cartao *</label>
                    <input type="text" id="card-holder-name" />
                </div>
                <div class="form-group">
                    <label for="card-number-full">@Strings.MetodosPagamento_numero_cartao *</label>
                    <input type="text" id="card-number-full" placeholder="xxxx xxxx xxxx xxxx" />
                </div>
                <div class="form-group">
                    <label for="card-expiry">@Strings.MetodosPagamento_data_validade *</label>
                    <input type="text" id="card-expiry" placeholder="MM / AA" style="max-width: 150px;" />
                </div>
                <div class="form-actions">
                    <button type="submit" class="form-btn-save">@Strings.MetodosPagamento_guardar</button>
                </div>
            </form>
        </div>
    </main>
</div>
