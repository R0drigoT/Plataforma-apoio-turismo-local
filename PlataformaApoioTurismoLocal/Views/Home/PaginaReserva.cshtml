@{
    var quarto = (ProjetoFim.Models.Quarto)ViewBag.Quarto;
    var dataInicio = (DateTime)ViewBag.DataInicio;
    var dataFim = (DateTime)ViewBag.DataFim;

    ViewBag.Title = ProjetoFim.Resources.Strings.PaginaReserva_finalizar_reserva;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using (Html.BeginForm("PaginaPagamento", "Home", FormMethod.Get))
{
    <input type="hidden" name="id" value="@quarto.Id" />
    <input type="hidden" name="dataInicio" value="@dataInicio.ToString("yyyy-MM-dd")" />
    <input type="hidden" name="dataFim" value="@dataFim.ToString("yyyy-MM-dd")" />

    <div class="booking-page-wrapper">
        <section class="booking-property-header">
            <div class="property-header-details">
                <h3>@quarto.Nome <span class="rating">★★★★☆</span></h3>
                <p class="address">@quarto.Localizacao</p>
            </div>
        </section>

        <div class="booking-page-container">
            <main class="booking-form-column">
                <div class="form-section">
                    <h2>@ProjetoFim.Resources.Strings.PaginaReserva_insira_os_seus_dados</h2>
                </div>

                <div class="booking-form">
                    <div class="form-row">
                        <div class="form-group half-width">
                            <label for="nome">@ProjetoFim.Resources.Strings.PaginaReserva_nome</label>
                            <input type="text" id="nome">
                        </div>
                        <div class="form-group half-width">
                            <label for="apelido">@ProjetoFim.Resources.Strings.PaginaReserva_apelido</label>
                            <input type="text" id="apelido">
                        </div>
                    </div>
                    <div class="form-actions-final">
                        <button type="submit" class="submit-booking-btn">@ProjetoFim.Resources.Strings.PaginaReserva_seguinte</button>
                    </div>
                </div>
            </main>
        </div>
    </div>
}
