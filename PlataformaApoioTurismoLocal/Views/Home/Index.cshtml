@model IEnumerable<ProjetoFim.Models.Quarto>
@using ProjetoFim.Resources

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Homepage";
}

<main>
    <section class="search-section">
        <div class="search-tabs">
            <button class="tab-link">@Strings.Search_Tab_Find</button>
            <button class="tab-link active">@Strings.Search_Tab_Rooms</button>
            <button class="tab-link" onclick="location.href='@Url.Action("Servicos", "Home")'">@Strings.Search_Tab_Services</button>
        </div>
        <form action="@Url.Action("ResultadosPesquisa", "Home")" method="get" class="search-bar">
            <div class="search-input">
                <label>@Strings.Search_Label_Location</label>
                <input type="text" name="localizacao" placeholder="@Strings.ResultadosPesquisa_diga_nos_onde_vai">
            </div>
            <div class="search-input">
                <label>@Strings.Search_Label_CheckIn</label>
                <input type="date" name="checkIn">
            </div>
            <div class="search-input">
                <label>@Strings.Search_Label_CheckOut</label>
                <input type="date" name="checkOut">
            </div>
            <div class="search-input">
                <label>@Strings.Search_Label_Guests</label>
                <input type="number" name="hospedes" placeholder="@Strings.ResultadosPesquisa_hospedes" min="1">
            </div>
            <button type="submit" class="search-button"><i class="fas fa-search"></i></button>
        </form>
    </section>

    @if (Model != null && Model.Any())
    {
        <section class="rooms-section">
            <h2>@Strings.Homepage_TopRated</h2>
            <div class="rooms-grid">
                @foreach (var quarto in Model)
                {
                    var imagemUrl = quarto.Imagens.OrderBy(i => i.Ordem).FirstOrDefault()?.Url ?? "/Content/placeholder.jpg";
                    <a href="@Url.Action("DetalhesQuarto", "Home", new { id = quarto.Id })" class="card-link">
                        <div class="room-card">
                            <div class="card-image" style="background-image: url('@Url.Content(imagemUrl)'); background-size: cover; background-position: center;">
                                <i class="far fa-heart favorite-icon-card"></i>
                            </div>
                            <div class="card-info">
                                <div class="rating">
                                    <i class="fas fa-star"></i> @quarto.AvaliacaoMedia.ToString("F1")
                                </div>
                                <h3>@quarto.Nome</h3>
                                <p>@quarto.Localizacao</p>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }
    else
    {
        <section class="rooms-section">
            <p>@Strings.Reservas_ainda_nao_efetuou_nenhuma_reserva</p>
        </section>
    }
</main>
