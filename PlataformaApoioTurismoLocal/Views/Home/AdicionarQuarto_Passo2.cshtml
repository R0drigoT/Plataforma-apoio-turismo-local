@model ProjetoFim.Models.Quarto
@using ProjetoFim.Resources
@{
    bool isEditing = Model != null && Model.Id > 0;
    ViewBag.Title = (isEditing ? Strings.Room_Edit : Strings.Room_Add) + " - " + Strings.Wizard_Step2;
    string formAction = isEditing ? "ModificarQuarto_Passo2" : "AdicionarQuarto_Passo2";
    string backAction = isEditing ? "ModificarQuarto_Passo1" : "AdicionarQuarto_Passo1";
}

<div class="admin-page-container">
    <div class="admin-page-header">
        <h1>@(isEditing ? Strings.Room_Edit : Strings.Room_Add)</h1>
        <p>@Strings.adicionarquarto_passo2_passo_2_de_5_instalacoes</p>
    </div>

    @using (Html.BeginForm(formAction, "Home", new { id = Model?.Id }, FormMethod.Post, new { id = "quartoForm" }))
    {
        @Html.AntiForgeryToken()

<div class="form-horizontal">
    <p>@Strings.adicionarquarto_passo2_indique_as_instalacoes_basicas_disponive</p>
    <hr />

    <div class="form-group">
        @Html.LabelFor(model => model.NumeroHospedes, htmlAttributes: new { @class = "control-label col-md-4" })
        <div class="col-md-8">
            @Html.EditorFor(model => model.NumeroHospedes, new { htmlAttributes = new { @class = "form-control", min = "0" } })
        </div>
    </div>


    <div class="form-group">
        @Html.LabelFor(model => model.NumeroCamasCasal, htmlAttributes: new { @class = "control-label col-md-4" })
        <div class="col-md-8">
            @Html.EditorFor(model => model.NumeroCamasCasal, new { htmlAttributes = new { @class = "form-control", min = "0" } })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.NumeroCamasSolteiro, htmlAttributes: new { @class = "control-label col-md-4" })
        <div class="col-md-8">
            @Html.EditorFor(model => model.NumeroCamasSolteiro, new { htmlAttributes = new { @class = "form-control", min = "0" } })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.NumeroCasasDeBanho, htmlAttributes: new { @class = "control-label col-md-4" })
        <div class="col-md-8">
            @Html.EditorFor(model => model.NumeroCasasDeBanho, new { htmlAttributes = new { @class = "form-control", min = "0" } })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.TemEstacionamento, htmlAttributes: new { @class = "control-label col-md-4" })
        <div class="col-md-8">
            <div class="inline-checkbox-group">
                @Html.EditorFor(model => model.TemEstacionamento)
                <label for="TemEstacionamento" style="font-weight:normal; margin-bottom:0;">@Strings.adicionarquarto_passo2_disponivel</label>
            </div>
        </div>
    </div>

    <div class="form-group">
        <div class="col-md-offset-2 col-md-10 form-actions">
            @Html.ActionLink(Strings.Confirm_Cancel, backAction, "Home", new { id = Model?.Id }, new { @class = "btn-cancel-form" })
            <input type="submit" value="@Strings.Auth_Continue" class="btn-primary" />
        </div>
    </div>
</div>
    }
</div>

<script>
    document.getElementById("quartoForm").addEventListener("submit", function (e) {
        const camasCasal = parseInt(document.getElementById("NumeroCamasCasal").value || 0);
        const camasSolteiro = parseInt(document.getElementById("NumeroCamasSolteiro").value || 0);

        if (camasCasal + camasSolteiro < 1) {
            e.preventDefault();
            alert("@Strings.Quarto_deve_ter_cama");
        }

    });
</script>

