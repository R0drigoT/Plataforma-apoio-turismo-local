@using ProjetoFim.Resources
@model PagedList.IPagedList<ProjetoFim.Models.Reserva>
@using PagedList.Mvc;
@using System.Globalization

@{
    ViewBag.Title = Strings.HistoricoTransacoes_consulte_todos_os_seus_pagamentos_e_reem;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culturaEuro = new CultureInfo("pt-PT");
}

<div class="admin-page-container">
    <div class="admin-page-header">
        <h1>@ViewBag.Title</h1>
        <p>@Strings.HistoricoTransacoes_consulte_todos_os_seus_pagamentos_e_reem</p>
    </div>
    <div class="reservations-table-container">
        <table class="reservations-table">
            <thead>
                <tr>
                    <th>@Strings.HistoricoTransacoes_data</th>
                    <th>@Strings.HistoricoTransacoes_descri_o</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th>@Strings.HistoricoTransacoes_utilizador</th>
                    }
                    <th>@Strings.HistoricoTransacoes_m_todo</th>
                    <th>@Strings.HistoricoTransacoes_total</th>
                    <th>@Strings.HistoricoTransacoes_fatura</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align:center;">
                            @Strings.HistoricoTransacoes_n_o_existem_transa_es_para_mostrar
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var transacao in Model)
                    {
                        var detalhe = transacao.DetalhesReserva.FirstOrDefault();
                        var lang = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName;
                        var tQuarto = detalhe?.Quarto?.Traducoes?.FirstOrDefault(x => x.Cultura == lang)
                                    ?? detalhe?.Quarto?.Traducoes?.FirstOrDefault(x => x.Cultura == "pt");
                        var tServico = detalhe?.Servico?.Traducoes?.FirstOrDefault(x => x.Cultura == lang)
                                    ?? detalhe?.Servico?.Traducoes?.FirstOrDefault(x => x.Cultura == "pt");
                        var nomeItem = tQuarto?.Nome ?? tServico?.Nome
                                    ?? detalhe?.Quarto?.Nome ?? detalhe?.Servico?.Nome
                                    ?? "Item Desconhecido";

                        <tr>
                            <td>@transacao.DataCriacao.ToShortDateString()</td>
                            <td>
                                @if (transacao.Estado == "Cancelada")
                                {
                                    <span>@Strings.HistoricoTransacoes_ver_nota_de_cr_dito #@transacao.Id - @nomeItem</span>
                                }
                                else
                                {
                                    <span>@Strings.HistoricoTransacoes_ver_fatura #@transacao.Id - @nomeItem</span>
                                }
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td>@transacao.Utilizador.UserName</td>
                            }
                            <td>(@Strings.HistoricoTransacoes_m_todo)</td>
                            <td class="@(transacao.Estado == "Cancelada" ? "amount-refunded" : "amount-paid")">
                                @(transacao.Estado == "Cancelada" ? "+ " : "- ") @transacao.ValorTotal.ToString("C", culturaEuro)
                            </td>
                            <td>
                                @if (transacao.Estado == "Cancelada")
                                {
                                    <a href="#" class="details-link">@Strings.HistoricoTransacoes_ver_nota_de_cr_dito</a>
                                }
                                else
                                {
                                    <a href="#" class="details-link">@Strings.HistoricoTransacoes_ver_fatura</a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
<div class="pagination-container">
    @Html.PagedListPager(Model, pagina => Url.Action("HistoricoTransacoes", new { pagina }))
</div>
