@model ProjetoFim.Models.Reserva
@{
    ViewBag.Title = "Reserva Confirmada";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var detalhe = Model.DetalhesReserva.FirstOrDefault();
}
@using System.Globalization
@{
    var culturaEuro = new CultureInfo("pt-PT");
}
<div class="page-container" style="text-align: center; max-width: 700px;">
    <div style="font-size: 60px; color: #28a745; margin-bottom: 20px;">
        <i class="fas fa-check-circle"></i>
    </div>

    <h1 class="page-title">Reserva Efetuada com Sucesso!</h1>
    <p class="page-description" style="font-size: 18px;">
        Obrigado pela sua reserva. Enviámos um e-mail de confirmação com todos os detalhes.
    </p>

    <div class="booking-summary-box" style="margin-top: 30px; text-align: left;">
        <h4>Sumário da Reserva</h4>
        <ul class="price-summary-list">
            <li class="price-item">
                <span>ID da Reserva:</span>
                <strong>#@Model.Id.ToString("D5")</strong>
            </li>
            @if (detalhe != null && detalhe.Quarto != null)
            {
                <li class="price-item">
                    <span>Alojamento:</span>
                    <strong>@detalhe.Quarto.Nome</strong>
                </li>
                <li class="price-item">
                    <span>Datas:</span>
                    <strong>@detalhe.DataInicio.Value.ToShortDateString() - @detalhe.DataFim.Value.ToShortDateString()</strong>
                </li>
            }
        </ul>
        <div class="price-total">
            <span>Preço Total Pago:</span>
            <strong>@Model.ValorTotal.ToString("C", culturaEuro)</strong>
        </div>
    </div>

    <div style="margin-top: 40px;">
        <a href="@Url.Action("Homepage", "Home")" class="btn-primary" style="margin-right: 15px;">Voltar à Homepage</a>
        <a href="@Url.Action("Reservas", "Home")" class="btn-secondary">Ver as Minhas Reservas</a>
    </div>
</div>