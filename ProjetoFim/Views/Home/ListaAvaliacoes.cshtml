@model PagedList.IPagedList<ProjetoFim.Models.Avaliacao>
@using PagedList.Mvc;
@using ProjetoFim.Resources
@{
    ViewBag.Title = Strings.GerirAvaliacoes_titulo;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="admin-page-container">
    <div class="admin-page-header">
        <h1>@Strings.GerirAvaliacoes_titulo</h1>
        <p>@Strings.ListaAvaliacoes_veja_e_gira_todas_as_avalia_es_deixadas_</p>
    </div>

    <div class="reservations-table-container">
        <table class="reservations-table">
            <thead>
                <tr>
                    <th>@Strings.ListaAvaliacoes_classifica_o</th>
                    <th>@Strings.ListaAvaliacoes_coment_rio</th>
                    <th>@Strings.ListaAvaliacoes_an_ncio</th>
                    <th>@Strings.ListaAvaliacoes_utilizador</th>
                    <th>@Strings.ListaAvaliacoes_data</th>
                    <th>@Strings.ListaAvaliacoes_a_es</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Classificacao ★</td>
                        <td>@item.Comentario</td>
                        <td>
                            @if (item.Quarto != null)
                            {
                                @item.Quarto.Nome
                            }
                            else if (item.Servico != null)
                            {
                                @item.Servico.Nome
                            }
                        </td>
                        <td>@item.Utilizador.UserName</td>
                        <td>@item.DataAvaliacao.ToShortDateString()</td>
                        <td>
                            @using (Html.BeginForm("Apagar", "Avaliacao", new { id = item.Id }, FormMethod.Post, new { @class = "form-apagar-avaliacao" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="delete-review-btn">@Strings.ListaAvaliacoes_apagar</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="pagination-container">
    @Html.PagedListPager(Model, pagina => Url.Action("ListaAvaliacoes", new { pagina }))
</div>
<script>
    $(document).ready(function () {
        $(document).on('submit', '.form-apagar-avaliacao', function (e) {
            e.preventDefault();
            if (confirm('@Strings.GerirAvaliacoes_confirmar_apagar')) {
                var form = $(this);
                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            form.closest('tr').fadeOut('slow');
                        } else {
                            alert('@Strings.GerirAvaliacoes_erro' + response.message);
                        }
                    }
                });
            }
        });
    });
</script>
