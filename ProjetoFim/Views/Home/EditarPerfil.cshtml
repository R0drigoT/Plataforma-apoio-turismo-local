@model ProjetoFim.Models.ApplicationUser
@using System.Globalization
@using ProjetoFim.Resources
@{
    ViewBag.Title = Strings.Menu_Profile;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="profile-page-container">
    @Html.Partial("_ProfileSummaryCard", Model)
    <main class="profile-main-content">

        <h1>@Strings.Menu_Profile</h1>
        <p class="member-since">@Strings.Perfil_membro_desde_2025.Replace("2025", Model.LockoutEndDateUtc.GetValueOrDefault(DateTime.Now).Year.ToString())</p>

        @using (Html.BeginForm("EditarPerfil", "Home", FormMethod.Post, new { @class = "profile-edit-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.Id)

            <div class="form-group">
                <label class="control-label col-md-3">@Strings.EditarPerfil_nome_de_utilizador</label>
                @Html.TextBoxFor(model => model.UserName, new { @class = "form-control" })
            </div>

            <div class="form-group">
                <label class="control-label col-md-3">@Strings.EditarPerfil_email</label>
                @Html.TextBoxFor(model => model.Email, new { @class = "form-control" })
            </div>

            <div class="form-group">
                <label class="control-label col-md-3">@Strings.EditarPerfil_telefone</label>
                @Html.TextBoxFor(model => model.PhoneNumber, new { @class = "form-control", placeholder = @Strings.EditarPerfil_o_seu_n_mero_de_telefone })
            </div>

            <div class="form-group">
                <label class="control-label col-md-3">@Strings.EditarPerfil_data_de_nascimento</label>
                @Html.TextBoxFor(model => model.DataDeNascimento, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
            </div>

            <div class="form-actions">
                <a href="@Url.Action("Perfil", "Home")" class="form-btn-cancel">@Strings.EditarPerfil_cancelar</a>
                <button type="submit" class="form-btn-save">@Strings.EditarPerfil_salvar</button>
            </div>
        }
    </main>
</div>
