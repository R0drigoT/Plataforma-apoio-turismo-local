@{
    ViewBag.Title = "Calendário de Disponibilidade";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="admin-page-container">
    <div class="admin-page-header">
        <h1>Calendário de Disponibilidade</h1>
        <p>Veja e gira a disponibilidade dos seus anúncios num só local.</p>
    </div>

    <div class="calendar-filter-bar">
        <label for="listing-select">Mostrar calendário para:</label>
