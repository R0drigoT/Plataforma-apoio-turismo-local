@model IEnumerable<ProjetoFim.Models.Notificacao>
@using ProjetoFim.Resources

@{
    ViewBag.Title = Strings.Menu_Notifications;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-container centered">
    <div class="notifications-panel">
        <div class="notifications-header">
            <h2>@Strings.Menu_Notifications</h2>
        </div>

        @Html.AntiForgeryToken()

        @foreach (var notificacao in Model)
        {
            <a href="@Url.Content(notificacao.Url ?? "#")"
               class="notification-item-link"
               data-id="@notificacao.Id">
                <div class="notification-item @(notificacao.Lida ? "" : "unread")">
                    <div class="notification-text">
                        <strong>@notificacao.Mensagem</strong>
                        <span>@notificacao.DataCriacao.ToString("g")</span>
                    </div>
                    <button class="notification-close" title="Fechar">&times;</button>
                </div>
            </a>
        }
    </div>
</div>
@section scripts {
    <script>
(function () {
    function postJson(url, data) {
        return fetch(url, {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: new URLSearchParams(data)
        }).then(r => r.json()).catch(() => ({ success: false }));
    }

    document.addEventListener('DOMContentLoaded', function () {
        var panel = document.querySelector('.notifications-panel');
        if (!panel) return;

        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        function marcarEremover(linkEl, navegar) {
            var id = linkEl.getAttribute('data-id');
            var href = linkEl.getAttribute('href') || '#';

            postJson('@Url.Action("MarcarComoLida","Home")', {
                __RequestVerificationToken: token,
                id: id
            }).finally(function () {
                // remover visualmente
                linkEl.style.transition = 'opacity .2s ease';
                linkEl.style.opacity = '0';
                setTimeout(function () {
                    linkEl.parentNode && linkEl.parentNode.removeChild(linkEl);
                    if (navegar && href && href !== '#') {
                        window.location = href;
                    }
                }, 200);
            });
        }

        panel.addEventListener('click', function (e) {
            var link = e.target.closest('.notification-item-link');
            if (!link) return;

            if (e.target.classList.contains('notification-close')) return;

            e.preventDefault();
            marcarEremover(link, true);
        });

        panel.addEventListener('click', function (e) {
            if (!e.target.classList.contains('notification-close')) return;
            e.preventDefault();
            e.stopPropagation();
            var link = e.target.closest('.notification-item-link');
            if (link) marcarEremover(link, false);
        });
    });
})();
    </script>
}


