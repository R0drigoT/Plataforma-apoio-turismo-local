@model IEnumerable<ProjetoFim.Models.Reserva>
@using ProjetoFim.Resources
@using System.Globalization

@{
    ViewBag.Title = Strings.Reservas_as_minhas_reservas;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culturaEuro = new CultureInfo("pt-PT");
}
@Html.AntiForgeryToken()

<div class="page-container">
    <h1 class="page-title">@Strings.Reservas_as_minhas_reservas</h1>
    <div class="tabs-container">
        <a href="@Url.Action("Reservas", "Home", new { filtro = "atuais" })"
           class="tab-btn @(ViewBag.FiltroAtivo == "atuais" ? "active" : "")">
            @Strings.Reservas_atuais
        </a>
        <a href="@Url.Action("Reservas", "Home", new { filtro = "passadas" })"
           class="tab-btn @(ViewBag.FiltroAtivo == "passadas" ? "active" : "")">
            @Strings.Reservas_passadas
        </a>
    </div>

    <div class="reservations-list">
        @if (!Model.Any())
        {
            <p>@Strings.Reservas_ainda_nao_efetuou_nenhuma_reserva</p>
        }
        else
        {
            foreach (var reserva in Model)
            {
                var detalhe = reserva.DetalhesReserva.FirstOrDefault();
                string actionName = detalhe.QuartoId != null ? "DetalhesQuarto" : "DetalhesServico";
                int? itemId = detalhe.QuartoId ?? detalhe.ServicoId;
                var imagemUrl = detalhe.Quarto?.Imagens.OrderBy(i => i.Ordem).FirstOrDefault()?.Url ?? "/Content/placeholder.jpg";
                if (detalhe == null) { continue; }

                <div class="reservation-card" id="reserva-card-@reserva.Id">
                    <a href="@Url.Action(actionName, "Home", new { id = itemId })">
                        <div class="reservation-image" style="background-image: url('@Url.Content(detalhe.Quarto?.Imagens.OrderBy(i => i.Ordem).FirstOrDefault()?.Url ?? "/Content/placeholder.jpg")'); background-size: cover; background-position: center;">
                        </div>
                    </a>
                    <div class="reservation-details">
                        <h3>
                            <a href="@Url.Action(actionName, "Home", new { id = itemId })" class="details-link">
                                @(detalhe.Quarto?.Nome ?? detalhe.Servico?.Nome ?? Strings.Reservas_item_removido)
                            </a>
                        </h3>
                        <p><strong>@Strings.Reservas_check_in</strong> @detalhe.DataInicio.Value.ToLongDateString()</p>
                        @if (detalhe.DataInicio != detalhe.DataFim)
                        {
                            <p><strong>@Strings.Reservas_check_out</strong> @detalhe.DataFim.Value.ToLongDateString()</p>
                        }
                        <p><strong>@Strings.Reservas_preco</strong> @reserva.ValorTotal.ToString("C", culturaEuro)</p>
                    </div>
                    <div class="reservation-info">
                        @if (detalhe.QuartoId != null)
                        {
                            <p><strong>@Strings.Reservas_duracao</strong> @((detalhe.DataFim.Value - detalhe.DataInicio.Value).Days) dias</p>
                        }
                        else
                        {
                            <p><strong>@Strings.Reservas_participantes</strong> @detalhe.Quantidade</p>
                        }
                        <p><strong>@Strings.Reservas_id_da_reserva</strong> #@reserva.Id.ToString("D5")</p>
                    </div>

                    <div class="reservation-actions">
                        @if (reserva.Estado == "Cancelamento Pedido")
                        {
                            <span class="status-badge" style="background-color: #ffc107; color: #333;">@Strings.Reservas_cancelamento_em_processamento</span>
                        }
                        else if (reserva.Estado.ToLower() != "cancelada" && reserva.Estado.ToLower() != "concluída")
                        {
                            <button type="button" class="btn-action cancel btn-cancelar-reserva" data-reserva-id="@reserva.Id">
                                @Strings.Reservas_cancelar_reserva
                            </button>
                        }
                        else
                        {
                            <span class="status-badge @reserva.Estado.ToLower()">@reserva.Estado</span>
                        }

                        <a href="@Url.Action("VerOuCriarConversa", "Mensagem", new { reservaId = reserva.Id })" class="btn-action message">
                            @Strings.Reservas_ver_iniciar_conversa
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>


@section scripts {
    <script>
    $(document).ready(function () {
        $('.btn-cancelar-reserva').on('click', function () {
            var confirmacao = confirm('@ProjetoFim.Resources.Strings.Reservas_confirmar_cancelamento');

            if (confirmacao) {
                var botao = $(this);
                var reservaId = botao.data('reserva-id');
                var token = $('input[name="__RequestVerificationToken"]').val();
                var url = '@Url.Action("Cancelar", "Reserva")';

                $.ajax({
                    type: 'POST',
                    url: url,
                    data: {
                        __RequestVerificationToken: token,
                        id: reservaId
                    },
                    success: function (response) {
                        if (response.success) {
                            var cardActions = botao.closest('.reservation-actions');
                            var linkConversa = cardActions.find('.message').clone();
                            var badgeHtml = '<span class="status-badge" style="background-color: #ffc107; color: #333;">@ProjetoFim.Resources.Strings.Reservas_cancelamento_em_processamento</span>';
                            cardActions.html(badgeHtml).append(linkConversa);
                        } else {
                            alert("@ProjetoFim.Resources.Strings.GerirAvaliacoes_erro " + response.message);
                        }
                    },
                    error: function () {
                        alert("@ProjetoFim.Resources.Strings.Aviso_erro_comunicacao");
                    }
                });
            }
        });
    });
    </script>
}
