@using ProjetoFim.Resources
@using Microsoft.AspNet.Identity
@using System.Globalization
@{
    ViewBag.Title = "Estatísticas";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culturaEuro = new CultureInfo("pt-PT");
}
<div class="admin-page-container">
    <div class="admin-page-header">
        <h1>@ViewBag.Title</h1>
        <p>Analise o desempenho da sua plataforma.</p>
    </div>

    <div class="stats-grid">
        <div class="stat-card"><h4>@Strings.Estatisticas_ganhos_totais</h4><span class="stat-value">@(((decimal)ViewBag.TotalGanhos).ToString("C", culturaEuro))</span></div>
        <div class="stat-card"><h4>@Strings.Estatisticas_total_de_reservas</h4><span class="stat-value">@ViewBag.TotalReservas</span></div>
        <div class="stat-card"><h4>@Strings.Estatisticas_valor_m_dio_reserva</h4><span class="stat-value">@(((decimal)ViewBag.MediaPorReserva).ToString("C", culturaEuro))</span></div>
    </div>

    <div class="stat-card large">
        <h4>@Strings.Estatisticas_ganhos_nos_ltimos_6_meses</h4>
        <canvas id="ganhosChart"></canvas>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('ganhosChart');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Encode(ViewBag.LabelsMeses)),
                    datasets: [{
                        label: '@ProjetoFim.Resources.Strings.Estatisticas_ganhos_euro_label',
                        data: @Html.Raw(Json.Encode(ViewBag.GanhosMensaisData)),
                        borderWidth: 1,
                        backgroundColor: 'rgba(0, 123, 255, 0.5)'
                    }]
                },
                options: {
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        });
    </script>
}
