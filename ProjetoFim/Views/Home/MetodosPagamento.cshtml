@{
    ViewBag.Title = "Métodos de pagamento";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="profile-page-container">
    <aside class="profile-summary-card">
        <div class="profile-pic-large"></div>
        <a href="#" class="photo-update-link">Atualize a foto</a>

        <div class="profile-card-actions">
            <a href="@Url.Action("EditarPerfil", "Home")" class="profile-action-btn">
                <i class="fas fa-user-edit"></i>
                <span>Dados Pessoais</span>
            </a>
            <a href="@Url.Action("MetodosPagamento", "Home")" class="profile-action-btn active">
                <i class="fas fa-credit-card"></i>
                <span>Metodos de pagamento</span>
            </a>
        </div>
    </aside>

    <main class="profile-main-content">
        <h1 class="page-title">Métodos de pagamento</h1>
        <p class="page-description">Adicione ou exclua métodos de pagamento de forma segura e facilite as reservas.</p>

        <div id="payment-methods-list">
            <hr class="section-divider">
            <div class="payment-method-item">
                <div class="payment-method-details">
                    <h4>Cartões de pagamento</h4>
                    <p>Pague com um novo cartão</p>
                </div>
                <div class="payment-method-action">
                    <a href="#" id="show-add-card-form-btn">Adicionar cartão</a>
                </div>
            </div>
            <hr class="section-divider">
        </div>

        <div id="add-card-form" class="add-card-container">
            <div class="add-card-header">
                <h4>Cartões de pagamento</h4>
                <a href="#" id="cancel-add-card-btn" class="form-btn-cancel">Cancelar</a>
            </div>
            <form class="profile-edit-form">
                <div class="form-group">
                    <label for="card-holder-name">Nome do titular do cartão *</label>
                    <input type="text" id="card-holder-name" />
                </div>
                <div class="form-group">
                    <label for="card-number-full">Número do cartão *</label>
                    <input type="text" id="card-number-full" placeholder="xxxx xxxx xxxx xxxx" />
                </div>
                <div class="form-group">
                    <label for="card-expiry">Data de validade *</label>
                    <input type="text" id="card-expiry" placeholder="MM / AA" style="max-width: 150px;" />
                </div>
                <div class="form-actions">
                    <button type="submit" class="form-btn-save">Guardar</button>
                </div>
            </form>
        </div>
    </main>
</div>