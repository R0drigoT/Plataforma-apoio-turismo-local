@model ProjetoFim.Models.HomepageViewModel
@using ProjetoFim.Resources

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Homepage";
    var currentLang = (string)ViewContext.RouteData.Values["lang"] ?? "pt";
}
@section styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
}
<main>
    <section class="search-section">
        <div class="search-tabs">
            <button class="tab-link">@Strings.Search_Tab_Find</button>
            <button class="tab-link active">@Strings.Search_Tab_Rooms</button>
            <button class="tab-link" onclick="location.href='@Url.Action("Servicos", "Home", new { lang = currentLang })'">@Strings.Search_Tab_Services</button>
        </div>
        <form action="@Url.Action("ResultadosPesquisa", "Home", new { lang = currentLang })" method="get" class="search-bar">
            <div class="search-input">
                <label>@Strings.Search_Label_Location</label>
                <input type="text" name="localizacao" placeholder="@Strings.ResultadosPesquisa_diga_nos_onde_vai">
            </div>
            <div class="search-input">
                <label>@Strings.Search_Label_CheckIn</label>
                <input type="text" name="checkIn" id="homepage-checkin-picker" placeholder="@Strings.ResultadosPesquisa_dd_mm_aaaa">
            </div>
            <div class="search-input">
                <label>@Strings.Search_Label_CheckOut</label>
                <input type="text" name="checkOut" id="homepage-checkout-picker" placeholder="@Strings.ResultadosPesquisa_dd_mm_aaaa">
            </div>
            <div class="search-input">
                <label>@Strings.Search_Label_Guests</label>
                <input type="number" name="hospedes" placeholder="@Strings.ResultadosPesquisa_hospedes" min="1">
            </div>
            <button type="submit" class="search-button"><i class="fas fa-search"></i></button>
        </form>
    </section>
    <section class="rooms-section">
        <div class="section-header">
            <h2>@Strings.Homepage_TopRated</h2>
            <div class="scroll-buttons">
                <button class="scroll-btn prev" data-target="melhores-avaliacoes-grid">&lt;</button>
                <button class="scroll-btn next" data-target="melhores-avaliacoes-grid">&gt;</button>
            </div>
        </div>
        <div class="rooms-grid" id="melhores-avaliacoes-grid">
            @Html.Partial("_ListaQuartosCard", Model.QuartosMelhorAvaliacao)
        </div>
    </section>
    <section class="rooms-section">
        <div class="section-header">
            <h2>@Strings.Homepage_NewRooms</h2>
            <div class="scroll-buttons">
                <button class="scroll-btn prev" data-target="recem-adicionados-grid">&lt;</button>
                <button class="scroll-btn next" data-target="recem-adicionados-grid">&gt;</button>
            </div>
        </div>
        <div class="rooms-grid" id="recem-adicionados-grid">
            @Html.Partial("_ListaQuartosCard", Model.QuartosRecemAdicionados)
        </div>
    </section>
    <section class="rooms-section">
        <div class="section-header">
            <h2>@Strings.Homepage_DiscountRooms</h2>
            <div class="scroll-buttons">
                <button class="scroll-btn prev" data-target="com-desconto-grid">&lt;</button>
                <button class="scroll-btn next" data-target="com-desconto-grid">&gt;</button>
            </div>
        </div>
        <div class="rooms-grid" id="com-desconto-grid">
            @Html.Partial("_ListaQuartosCard", Model.QuartosComDesconto)
        </div>
    </section>
</main>
@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var checkoutPicker = flatpickr("#homepage-checkout-picker", {
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "d/m/Y",
                minDate: new Date().fp_incr(1)
            });

            flatpickr("#homepage-checkin-picker", {
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "d/m/Y",
                minDate: "today",
                onChange: function (selectedDates, dateStr, instance) {
                    if (selectedDates.length > 0) {
                        checkoutPicker.set('minDate', new Date(selectedDates[0]).fp_incr(1));
                    }
                }
            });
            document.querySelectorAll('.scroll-btn').forEach(button => {
                button.addEventListener('click', function () {
                    const targetId = this.dataset.target;
                    const grid = document.getElementById(targetId);
                    const scrollAmount = this.classList.contains('prev') ? -300 : 300;
                    grid.scrollBy({ left: scrollAmount, behavior: 'smooth' });
                });

            });
        });
    </script>
}
<style>
    .room-card {
        position: relative;
    }

    .favorite-btn-card {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: rgba(0,0,0,0.3);
        color: white;
        border: none;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        font-size: 18px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s;
        z-index: 10;
    }

        .favorite-btn-card:hover {
            transform: scale(1.1);
        }

        .favorite-btn-card .fa-heart.fas {
            color: #E53935;
        }
</style>

