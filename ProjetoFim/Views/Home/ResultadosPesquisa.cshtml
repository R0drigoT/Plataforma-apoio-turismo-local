@model IEnumerable<ProjetoFim.Models.Quarto>
@using ProjetoFim.Resources
@{
    ViewBag.Title = Strings.ResultadosPesquisa_resultados_da_pesquisa_de_quartos;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
}
<div class="service-results-container">
    <div class="results-header">
        <h3>@Model.Count() resultado(s) encontrado(s)</h3>
        <button class="filter-btn"><i class="fas fa-filter"></i> @Strings.ResultadosPesquisa_filtros</button>
    </div>

    <section class="search-section">
        <form action="@Url.Action("ResultadosPesquisa", "Home")" method="get" class="search-bar">
            <div class="search-input">
                <label>@Strings.Search_Label_Location</label>
                <input type="text" name="localizacao" placeholder="@Strings.ResultadosPesquisa_diga_nos_onde_vai">
            </div>
            <div class="search-input">
                <label>@Strings.ResultadosPesquisa_check_in</label>
                <input type="text" name="checkIn" id="homepage-checkin-picker" placeholder="@Strings.ResultadosPesquisa_dd_mm_aaaa">
            </div>
            <div class="search-input">
                <label>@Strings.ResultadosPesquisa_check_out</label>
                <input type="text" name="checkOut" id="homepage-checkout-picker" placeholder="@Strings.ResultadosPesquisa_dd_mm_aaaa">
            </div>
            <div class="search-input">
                <label>@Strings.ResultadosPesquisa_hospedes</label>
                <input type="number" name="hospedes" placeholder="@Strings.ResultadosPesquisa_hospedes" min="1">
            </div>
            <button type="submit" class="search-button"><i class="fas fa-search"></i></button>
        </form>
    </section>

    <div class="services-results-grid">
        @if (!Model.Any())
        {
            <p>@Strings.ResultadosPesquisa_nenhum_servico_encontrado_com_os_criteri</p>
        }
        else
        {
            @Html.Partial("_ListaQuartosCard", Model)
        }
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var checkoutPicker = flatpickr("#resultados-checkout-picker", {
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "d/m/Y",
                minDate: new Date().fp_incr(1)
            });

            flatpickr("#resultados-checkin-picker", {
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "d/m/Y",
                minDate: "today",
                onChange: function (selectedDates, dateStr, instance) {
                    if (selectedDates.length > 0) {
                        checkoutPicker.set('minDate', new Date(selectedDates[0]).fp_incr(1));
                    }
                }
            });
        });
    </script>
}