@model ProjetoFim.Models.DashboardViewModel
@using ProjetoFim.Resources
@{
    ViewBag.Title = Strings.Dashboard_titulo;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using System.Globalization
@{
    var culturaEuro = new CultureInfo("pt-PT");
}
<div class="admin-page-container">
    <div class="admin-page-header">
        <h1>@Strings.Dashboard_titulo</h1>
        <p>@Strings.Dashboard_bem_vindo_gestor</p>
    </div>
    <div class="dashboard-summary-cards">
        <a href="@Url.Action("ListaReservas", "Home", new {  estado = "Pendente", data = DateTime.Today.ToString("yyyy-MM-dd") })" class="summary-card-link">
            <div class="summary-card">
                <div class="card-icon"><i class="fas fa-calendar-check"></i></div>
                <div class="card-content">
                    <span class="card-value">@Model.ReservasPendentes</span>
                    <span class="card-label">@Strings.Dashboard_novas_reservas_hoje</span>
                </div>
            </div>
        </a>
        <a href="@Url.Action("ListaReservas", "Home", new { estado = "Confirmada", data = DateTime.Today.ToString("yyyy-MM-dd") })" class="summary-card-link">
            <div class="summary-card">
                <div class="card-icon"><i class="fas fa-door-open"></i></div>
                <div class="card-content">
                    <span class="card-value">@Model.CheckInsParaHoje</span>
                    <span class="card-label">@Strings.Dashboard_checkins_hoje</span>
                </div>
            </div>
        </a>
        <a href="@Url.Action("Estatisticas", "Home")" class="summary-card-link">
            <div class="summary-card">
                <div class="card-icon"><i class="fas fa-euro-sign"></i></div>
                <div class="card-content">
                    <span class="card-value">@Model.GanhosDoMes.ToString("C", culturaEuro)</span>
                    <span class="card-label">@Strings.Dashboard_ganhos_mes</span>
                </div>
            </div>
        </a>
        <a href="@Url.Action("CaixaDeEntrada", "Mensagem", new { filtro = "nao-lidas" })" class="summary-card-link">
            <div class="summary-card">
                <div class="card-icon"><i class="fas fa-envelope"></i></div>
                <div class="card-content">
                    <span class="card-value">@Model.MensagensNaoLidas</span>
                    <span class="card-label">@Strings.Dashboard_mensagens_por_ler</span>
                </div>
            </div>
        </a>
    </div>

    <div class="recent-activity-panel">
        <h2>@Strings.Dashboard_atividade_recente</h2>
        <div class="activity-list">
            @if (!Model.AtividadeRecente.Any())
            {
                <p>@Strings.Dashboard_sem_atividade</p>
            }
            else
            {
                foreach (var atividade in Model.AtividadeRecente)
                {
                    var detalhe = atividade.DetalhesReserva.FirstOrDefault();
                    var nomeItem = detalhe?.Quarto?.Nome ?? detalhe?.Servico?.Nome ?? "N/A";
                    <a href="@Url.Action("Detalhes", "Reserva", new { id = atividade.Id })" class="activity-item-link">
                        <div class="activity-item">
                            <div class="activity-icon new-booking"><i class="fas fa-calendar-plus"></i></div>
                            <div class="activity-details">
                                <p><strong>@Strings.Dashboard_nova_reserva</strong> @Strings.Dashboard_para @nomeItem @Strings.Dashboard_de <strong>@atividade.Utilizador.UserName</strong>.</p>
                                <small>@atividade.DataCriacao.ToString("g")</small>
                            </div>
                        </div>
                    </a>
                }
            }
        </div>
    </div>
</div>
