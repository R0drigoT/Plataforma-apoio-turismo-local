<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Alojamento</title>
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="navbar-container">
                <a href="@Url.Action(User.Identity.IsAuthenticated ? (User.IsInRole("Admin") ? "Dashboard" : "Homepage") : "Index", "Home")" class="navbar-logo">
                    <img src="https://i.imgur.com/your-logo-image.png" alt="Logo">
                </a>
                <div class="navbar-menu">
                    @if (User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            // --- MENU DE GESTOR/ADMIN ---
                            <a href="@Url.Action("GerirAnuncios", "Home")">Anúncios</a>
                            <a href="@Url.Action("ListaReservas", "Home")">Reservas</a>
                            <a href="@Url.Action("Calendario", "Home")">Calendário</a>
                            <a href="@Url.Action("CaixaDeEntrada", "Home")">Caixa de Entrada</a>
                            <a href="@Url.Action("Estatisticas", "Home")">Estatísticas</a>
                        }
                        else
                        {
                            // --- MENU DE UTILIZADOR NORMAL ---
                            <a href="@Url.Action("Reservas", "Home")">Reservas</a>
                            <a href="@Url.Action("Favoritos", "Home")">Favoritos</a>
                        }
                        <a href="#">Selecione o idioma</a>
                        <div class="user-menu-container">
                            <div class="user-icon-wrapper" id="userMenuIcon">
                                <i class="fas fa-bars"></i>
                                <i class="fas fa-user-circle"></i>
                            </div>
                            <div id="loginOptions" class="login-options clean-menu">
                                @if (User.IsInRole("Admin"))
                                {
                                    // --- DROPDOWN PARA ADMIN ---
                                    <div class="login-section">
                                        <a href="@Url.Action("Notificacoes", "Home")" class="dropdown-link">Notificações</a>
                                        <a href="#" class="dropdown-link">Histórico de transações</a>
                                    </div>
                                    <div class="login-section">
                                        @using (Html.BeginForm("Logout", "Account", FormMethod.Post, new { id = "logoutFormAdmin" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <a href="javascript:document.getElementById('logoutFormAdmin').submit()" class="dropdown-link">Logout</a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    // --- DROPDOWN PARA UTILIZADOR NORMAL ---
                                    <div class="login-section">
                                        <a href="@Url.Action("Mensagens", "Home")" class="dropdown-link">Mensagens</a>
                                        <a href="@Url.Action("Notificacoes", "Home")" class="dropdown-link">Notificações</a>
                                        <a href="@Url.Action("HistoricoTransacoes", "Home")" class="dropdown-link">Histórico de transações</a>
                                    </div>
                                    <div class="login-section">
                                        <a href="@Url.Action("Perfil", "Home")" class="dropdown-link">Perfil</a>
                                        @using (Html.BeginForm("Logout", "Account", FormMethod.Post, new { id = "logoutForm" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <a href="javascript:document.getElementById('logoutForm').submit()" class="dropdown-link">Logout</a>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        // --- MENU PARA UTILIZADOR ANÓNIMO ---
                        <a href="#">Selecione o idioma</a>
                        <div class="user-menu-container">
                            <div class="user-icon-wrapper" id="userMenuIcon">
                                <i class="fas fa-bars"></i>
                                <i class="fas fa-user-circle"></i>
                            </div>
                            <div id="loginOptions" class="login-options">
                                <div class="login-section">
                                    <strong>Utilizador</strong>
                                    <a href="#" id="openRegisterBtn" class="btn-login">Registar</a>
                                    <a href="#" id="openLoginBtn" class="btn-login">Login</a>
                                </div>
                                <div class="login-section">
                                    <strong>Admin</strong>
                                    <a href="#" id="openAdminLoginBtn" class="btn-login">Login</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container body-content">
        @RenderBody()
    </div>

    @if (!User.Identity.IsAuthenticated)
    {
        <div id="loginModal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Login</h2>
                    <button class="close-btn">&times;</button>
                </div>
                <form action="@Url.Action("Login", "Account")" method="post">
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="login-username">Nome do Utilizador</label>
                            <input type="text" id="login-username" name="Username" placeholder="Introduza o nome de Utilizador" required>
                        </div>
                        <div class="form-group">
                            <label for="login-password">Password</label>
                            <input type="password" id="login-password" name="Password" placeholder="Introduza a sua Password" required>
                        </div>
                        <a href="#" class="forgot-password">Esqueceu-se da Password?</a>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="modal-btn">Continue</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="registerModal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Registar</h2>
                    <button class="close-btn">&times;</button>
                </div>
                <form id="registerForm" action="@Url.Action("Registar", "Account")" method="post">
                    <div class="modal-body">
                        <div id="register-errors" class="form-errors"></div>
                        <div class="form-group">
                            <label for="reg-username">Nome do Utilizador</label>
                            <input type="text" id="reg-username" name="Username" placeholder="Introduza o nome de Utilizador" required>
                        </div>
                        <div class="form-group">
                            <label for="reg-dob">Data de Nascimento</label>
                            <input type="date" id="reg-dob" name="DateOfBirth" required>
                        </div>
                        <div class="form-group">
                            <label for="reg-password">Password</label>
                            <input type="password" id="reg-password" name="Password" placeholder="Introduza a sua Password" required>
                        </div>
                        <div class="form-group">
                            <label for="reg-confirm-password">Confirme a Password</label>
                            <input type="password" id="reg-confirm-password" name="ConfirmPassword" placeholder="Introduza a sua Password" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="registerSubmitBtn" class="modal-btn">Continue</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="adminLoginModal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Login de Administrador</h2>
                    <button class="close-btn">&times;</button>
                </div>
                <form action="@Url.Action("Login", "Account")" method="post">
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="admin-username">Nome do Admin</label>
                            <input type="text" id="admin-username" name="Username" placeholder="Introduza o nome de Admin" required>
                        </div>
                        <div class="form-group">
                            <label for="admin-password">Password</label>
                            <input type="password" id="admin-password" name="Password" placeholder="Introduza a sua Password" required>
                        </div>
                        <a href="#" class="forgot-password">Esqueceu-se da senha?</a>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="modal-btn">Continue</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <footer>
        <p>&copy; @DateTime.Now.Year - Meu Projeto de Alojamento</p>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Lógica do menu dropdown
            const userMenuIcon = document.getElementById('userMenuIcon');
            const loginOptions = document.getElementById('loginOptions');
            if (userMenuIcon) {
                userMenuIcon.addEventListener('click', function (event) {
                    event.stopPropagation();
                    if (loginOptions) {
                        loginOptions.classList.toggle('show');
                    }
                });
            }
            document.addEventListener('click', function (event) {
                if (loginOptions && loginOptions.classList.contains('show')) {
                    const isClickInside = userMenuIcon.contains(event.target) || loginOptions.contains(event.target);
                    if (!isClickInside) {
                        loginOptions.classList.remove('show');
                    }
                }
            });

            // Lógica dos modais (SÓ PARA ANÓNIMOS)
            if (!@User.Identity.IsAuthenticated.ToString().ToLower()) {
                const loginModal = document.getElementById('loginModal');
                const registerModal = document.getElementById('registerModal');
                const adminLoginModal = document.getElementById('adminLoginModal');
                const openLoginBtn = document.getElementById('openLoginBtn');
                const openRegisterBtn = document.getElementById('openRegisterBtn');
                const openAdminLoginBtn = document.getElementById('openAdminLoginBtn');
                const closeButtons = document.querySelectorAll('.close-btn');
                const overlays = document.querySelectorAll('.modal-overlay');

                function openModal(modal) { if (modal) modal.style.display = 'flex'; }
                function closeModal() {
                    if (loginModal) loginModal.style.display = 'none';
                    if (registerModal) registerModal.style.display = 'none';
                    if (adminLoginModal) adminLoginModal.style.display = 'none';
                }

                if (openLoginBtn) openLoginBtn.addEventListener('click', function (e) { e.preventDefault(); openModal(loginModal); });
                if (openRegisterBtn) openRegisterBtn.addEventListener('click', function (e) { e.preventDefault(); openModal(registerModal); });
                if (openAdminLoginBtn) openAdminLoginBtn.addEventListener('click', function (e) { e.preventDefault(); openModal(adminLoginModal); });

                if (closeButtons.length > 0) {
                    closeButtons.forEach(button => button.addEventListener('click', closeModal));
                }
                if (overlays.length > 0) {
                    overlays.forEach(overlay => {
                        overlay.addEventListener('click', function (event) {
                            if (event.target === overlay) closeModal();
                        });
                    });
                }
            }

            // Lógica AJAX para o formulário de registo
            const registerSubmitBtn = document.getElementById('registerSubmitBtn');
            if (registerSubmitBtn) {
                registerSubmitBtn.addEventListener('click', function (event) {
                    event.preventDefault();
                    const registerForm = document.getElementById('registerForm');
                    const errorDiv = document.getElementById('register-errors');
                    errorDiv.style.display = 'none';
                    errorDiv.innerHTML = '';

                    fetch(registerForm.action, {
                        method: registerForm.method,
                        body: new FormData(registerForm)
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            window.location.href = data.redirectUrl;
                        } else {
                            let errorList = '<ul>';
                            data.errors.forEach(function (error) { errorList += '<li>' + error + '</li>'; });
                            errorList += '</ul>';
                            errorDiv.innerHTML = errorList;
                            errorDiv.style.display = 'block';
                        }
                    })
                    .catch(error => {
                        errorDiv.innerHTML = '<ul><li>Ocorreu um erro inesperado. Por favor, tente novamente.</li></ul>';
                        errorDiv.style.display = 'block';
                    });
                });
            }
            // --- LÓGICA PARA A PÁGINA DE MÉTODOS DE PAGAMENTO ---

            const paymentList = document.getElementById('payment-methods-list');

            const addCardForm = document.getElementById('add-card-form');

            const showFormBtn = document.getElementById('show-add-card-form-btn');

            const cancelBtn = document.getElementById('cancel-add-card-btn');



            if (showFormBtn) {

                showFormBtn.addEventListener('click', function (event) {

                    event.preventDefault();

                    if (paymentList) paymentList.style.display = 'none';

                    if (addCardForm) addCardForm.style.display = 'block';

                });

            }

            if (cancelBtn) {

                cancelBtn.addEventListener('click', function (event) {

                    event.preventDefault();

                    if (paymentList) paymentList.style.display = 'block';

                    if (addCardForm) addCardForm.style.display = 'none';

                });

            }



            // --- LÓGICA DO BOTÃO DE FAVORITOS ---

            const heartIcon = document.getElementById('favorite-heart-icon');

            if (heartIcon) {

                heartIcon.addEventListener('click', function () {

                    this.classList.toggle('far');

                    this.classList.toggle('fas');

                    this.classList.toggle('is-favorite');

                });

            }



        });

    </script>

</body>

</html>